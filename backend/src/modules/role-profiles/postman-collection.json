  "item": [
    {
      "name": "Create Profiles",
      "item": [
        {
          "name": "Create Student Profile",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{studentUserId}}\",\n  \"role\": \"student\",\n  \"commonFields\": {\n    \"name\": \"Alex Chen\",\n    \"email\": \"alex.chen@university.edu\",\n    \"profilePhoto\": \"https://example.com/alex.jpg\",\n    \"bio\": \"Computer Science student passionate about full-stack development\",\n    \"location\": \"Boston, MA\"\n  },\n  \"roleSpecificData\": {\n    \"skills\": [\"JavaScript\", \"TypeScript\", \"React\", \"Node.js\", \"Python\"],\n    \"education\": [\n      {\n        \"institution\": \"Massachusetts Institute of Technology\",\n        \"degree\": \"Bachelor of Science\",\n        \"fieldOfStudy\": \"Computer Science\",\n        \"startYear\": 2021,\n        \"endYear\": 2025,\n        \"grade\": \"3.9 GPA\"\n      }\n    ],\n    \"projects\": [\n      {\n        \"title\": \"E-Commerce Platform\",\n        \"description\": \"Built a full-stack e-commerce platform with React and Node.js\",\n        \"technologies\": [\"React\", \"Node.js\", \"PostgreSQL\"],\n        \"link\": \"https://github.com/alexchen/ecommerce\",\n        \"startDate\": \"2023-09\",\n        \"endDate\": \"2024-01\"\n      }\n    ],\n    \"interests\": [\"Web Development\", \"Machine Learning\", \"Open Source\"],\n    \"internshipAvailable\": true,\n    \"internshipExperience\": [\n      {\n        \"company\": \"TechStart Inc.\",\n        \"role\": \"Software Engineering Intern\",\n        \"duration\": \"3 months\",\n        \"description\": \"Developed REST APIs using Node.js and Express\"\n      }\n    ]\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/role-profiles",
              "host": ["{{baseUrl}}"],
              "path": ["api", "role-profiles"]
            }
          }
        },
        {
